  <sharedProfiles>
    <profile id="nflb-prof-ability-coc" name="Combined Operations" hidden="false" typeId="9cc3-6d83-4dd3-9b64" typeName="Abilities">
      <characteristics>
        <characteristic name="Description" typeId="9b8f-694b-e5e-b573">The Platoon counts as 1 unit for army construction, target selection, and points counting. Sub-squads target separately in the Shooting phase, may declare Charges separately, and contribute OC independently. The Platoon is destroyed only when every sub-squad is destroyed.</characteristic>
      </characteristics>
    </profile>
    <profile id="nflb-prof-ability-won" name="Iron Discipline" hidden="false" typeId="9cc3-6d83-4dd3-9b64" typeName="Abilities">
      <characteristics>
        <characteristic name="Description" typeId="9b8f-694b-e5e-b573">While the Platoon Commander is on the battlefield, sub-squads in this Platoon may re-roll failed Battle-shock tests. If no Castellan is taken, a Named Officer Character leading the Platoon fulfils this role.</characteristic>
      </characteristics>
    </profile>
    <profile id="nflb-prof-ability-orders" name="Coordinated Disembark" hidden="false" typeId="9cc3-6d83-4dd3-9b64" typeName="Abilities">
      <characteristics>
        <characteristic name="Description" typeId="9b8f-694b-e5e-b573">When a Transport carrying a sub-squad from this Platoon is destroyed, the disembarked models gain Stealth and Benefit of Cover until the start of your next Movement phase.</characteristic>
      </characteristics>
    </profile>
    <profile id="nflb-prof-chimera" name="Chimera" hidden="false" typeId="c547-1836-d8a-ff4f" typeName="Unit">
      <characteristics>
        <characteristic name="M" typeId="e703-ecb6-5ce7-aec1">10"</characteristic>
        <characteristic name="T" typeId="d29d-cf75-fc2d-34a4">9</characteristic>
        <characteristic name="SV" typeId="450-a17e-9d5e-29da">3+</characteristic>
        <characteristic name="W" typeId="750a-a2ec-90d3-21fe">11</characteristic>
        <characteristic name="LD" typeId="58d2-b879-49c7-43bc">7+</characteristic>
        <characteristic name="OC" typeId="bef7-942a-1a23-59f8">2</characteristic>
      </characteristics>
    </profile>
    <profile id="nflb-prof-transport-note" name="Transports" hidden="false" typeId="9cc3-6d83-4dd3-9b64" typeName="Abilities">
      <characteristics>
        <characteristic name="Description" typeId="9b8f-694b-e5e-b573">Each Infantry Squad has an optional Chimera Transport (70pts) built in — select it from within the squad entry. The PCS, Heavy Weapons Squad, and Special Weapons Squad may also take a Chimera (add separately, 70pts each). The Platoon Commander may issue Orders while embarked (measure from the Chimera).</characteristic>
      </characteristics>
    </profile>
    <profile id="nflb-prof-pcs-wargear" name="PCS Base — Wargear Options" hidden="false" typeId="9cc3-6d83-4dd3-9b64" typeName="Abilities">
      <characteristics>
        <characteristic name="Description" typeId="9b8f-694b-e5e-b573">4 Veteran Guardsmen. Default: Lasgun, Close Combat Weapon, Frag and Krak Grenades. Each of the 4 may freely (free of cost): replace Lasgun with a Special Weapon (Flamer, Grenade Launcher, Meltagun, Plasma Gun, Sniper Rifle, or Demolition Charge); or become a Specialist — Vox-caster, Medi-pack, Regimental Standard, or Master Vox (max 1 of each Specialist type per PCS).</characteristic>
      </characteristics>
    </profile>
    <profile id="nflb-prof-castellan-wargear" name="Generic Platoon Castellan — Wargear" hidden="false" typeId="9cc3-6d83-4dd3-9b64" typeName="Abilities">
      <characteristics>
        <characteristic name="Description" typeId="9b8f-694b-e5e-b573">Default: Laspistol, Chainsword, Frag and Krak Grenades. Free swaps: Laspistol → Bolt Pistol or Plasma Pistol; Chainsword → Power Weapon or Power Fist. Issues Orders via Voice of Command (2 Orders to Regiment units). Omit this entry if a Named Officer Character leads the Platoon instead.</characteristic>
      </characteristics>
    </profile>
    <profile id="nflb-prof-is-composition" name="Infantry Squad — Composition" hidden="false" typeId="9cc3-6d83-4dd3-9b64" typeName="Abilities">
      <characteristics>
        <characteristic name="Description" typeId="9b8f-694b-e5e-b573">10 models: 1 Sergeant + 9 Guardsmen. Sergeant: Laspistol, Chainsword, Grenades (free swaps: Laspistol → Bolt/Plasma Pistol; Chainsword → Power Weapon/Power Fist). Guardsmen: Lasgun, Close Combat Weapon, Grenades. Optional upgrades per squad (all free, max 1 each): Special Weapon — one Guardsman replaces Lasgun with Flamer, Grenade Launcher, Meltagun, Plasma Gun, Sniper Rifle, or Demolition Charge. Heavy Weapon Team — two Guardsmen with one of: Autocannon, Heavy Bolter, Lascannon, Missile Launcher, Mortar, or Heavy Stubber. Specialist — one Guardsman becomes Vox-caster, Medi-pack bearer, or Regimental Standard bearer.</characteristic>
      </characteristics>
    </profile>
    <profile id="nflb-prof-hws-composition" name="Heavy Weapons Squad — Composition" hidden="false" typeId="9cc3-6d83-4dd3-9b64" typeName="Abilities">
      <characteristics>
        <characteristic name="Description" typeId="9b8f-694b-e5e-b573">6 models: 3 Heavy Weapons Teams (gunner + loader each). Each team freely selects one heavy weapon (mix-and-match): Autocannon, Heavy Bolter, Lascannon, Missile Launcher, Mortar, or Heavy Stubber. Each model also carries Laspistol, Close Combat Weapon, and Grenades.</characteristic>
      </characteristics>
    </profile>
    <profile id="nflb-prof-sws-composition" name="Special Weapons Squad — Composition" hidden="false" typeId="9cc3-6d83-4dd3-9b64" typeName="Abilities">
      <characteristics>
        <characteristic name="Description" typeId="9b8f-694b-e5e-b573">5 models: 1 Sergeant + 4 Special Weapons Guardsmen. Sergeant: Laspistol, Chainsword, Grenades. Each of the 4 Guardsmen freely selects one special weapon (mix-and-match, no duplicate cap): Flamer, Grenade Launcher, Meltagun, Plasma Gun, Sniper Rifle, or Demolition Charge.</characteristic>
      </characteristics>
    </profile>
