    <profile id="nflb-wp-voxcaster" name="Vox-Caster" hidden="false" typeId="9cc3-6d83-4dd3-9b64" typeName="Abilities">
      <characteristics>
        <characteristic name="Description" typeId="9b8f-694b-e5e-b573">While this unit contains a Vox-Caster, Orders issued to this unit may be relayed up to 24" (instead of the standard range). In addition, if an Order check fails for this unit, you may re-roll the check once.</characteristic>
      </characteristics>
    </profile>
    <profile id="nflb-wp-medipack" name="Medi-Pack" hidden="false" typeId="9cc3-6d83-4dd3-9b64" typeName="Abilities">
      <characteristics>
        <characteristic name="Description" typeId="9b8f-694b-e5e-b573">Models in this unit have a 5+ Feel No Pain.</characteristic>
      </characteristics>
    </profile>
    <profile id="nflb-wp-regstandard" name="Regimental Standard" hidden="false" typeId="9cc3-6d83-4dd3-9b64" typeName="Abilities">
      <characteristics>
        <characteristic name="Description" typeId="9b8f-694b-e5e-b573">While this unit contains a Regimental Standard, this unit and friendly **^^Infantry Platoon [NFLB]^^** sub-squads within 6" automatically pass Battle-shock tests.</characteristic>
      </characteristics>
    </profile>
    <profile id="nflb-wp-mastervox" name="Master Vox" hidden="false" typeId="9cc3-6d83-4dd3-9b64" typeName="Abilities">
      <characteristics>
        <characteristic name="Description" typeId="9b8f-694b-e5e-b573">While this model&apos;s unit contains a Master Vox, the Platoon Commander may issue Orders to any friendly **^^Astra Militarum^^** unit on the battlefield, regardless of range.</characteristic>
      </characteristics>
    </profile>
    <profile id="nflb-prof-krak" name="Krak Grenade" hidden="false" typeId="f77d-b953-8fa4-b762" typeName="Ranged Weapons">
      <characteristics>
        <characteristic name="Range" typeId="9896-9419-16a1-92fc">6"</characteristic>
        <characteristic name="A" typeId="3bb-c35f-f54-fb08">1</characteristic>
