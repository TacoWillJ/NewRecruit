  </sharedProfiles>

  <!-- ============================================================
       SHARED SELECTION ENTRIES
       The Infantry Platoon and its component units.
       These appear in the army builder as additional choices
       alongside the standard AM roster — not instead of it.
       ============================================================ -->
  <sharedSelectionEntries>

    <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
         INFANTRY PLATOON v3
         Regiment-agnostic. Flat 10e pricing.
         1 Platoon Command Squad (mandatory) + 2-5 Infantry Squads
         ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
    <selectionEntry id="nflb-se-platoon"
                    name="Infantry Platoon [NFLB]"
                    hidden="false"
                    collective="false"
                    import="true"
                    type="unit">

      <publicationLinks>
        <publicationLink id="nflb-pl-platoon" targetId="nflb-pub-main"/>
      </publicationLinks>

      <categoryLinks>
        <!-- Primary slot: Troops -->
        <categoryLink id="nflb-cl-plat-troops"
                      name="Troops"
                      hidden="false"
                      targetId="3d52-fccf-a302-troops"
                      primary="true"/>
        <!-- Faction keywords inherited from official AM catalogue link -->
        <categoryLink id="nflb-cl-plat-am"
                      name="Faction: Astra Militarum"
                      hidden="false"
                      targetId="fa45-57e-930e-602b"
                      primary="false"/>
        <categoryLink id="nflb-cl-plat-imp"
                      name="Imperium"
                      hidden="false"
                      targetId="8d6d-8c4b-f475-e74a"
                      primary="false"/>
        <categoryLink id="nflb-cl-plat-inf"
                      name="Infantry"
                      hidden="false"
                      targetId="96c1-32dc-d9dc-4678"
                      primary="false"/>
      </categoryLinks>

      <!-- Platoon-level abilities -->
      <infoLinks>
        <infoLink id="nflb-il-coc" name="Chain of Command" hidden="false"
                  targetId="nflb-prof-ability-coc" type="profile"/>
        <infoLink id="nflb-il-won" name="Weight of Numbers" hidden="false"
                  targetId="nflb-prof-ability-won" type="profile"/>
      </infoLinks>

      <!-- Platoon has no base cost — cost comes from sub-units -->
      <costs>
        <cost name="pts" typeId="points" value="0"/>
      </costs>

      <selectionEntries>

        <!-- ======================================================
             PLATOON COMMAND SQUAD — exactly 1, mandatory
             4 models: 1 Platoon Commander + 3 Veteran Guardsmen
             40pts flat
             ====================================================== -->
        <selectionEntry id="nflb-se-pcs"
                        name="Platoon Command Squad"
                        hidden="false"
                        collective="false"
                        import="true"
                        type="unit">

          <publicationLinks>
            <publicationLink id="nflb-pl-pcs" targetId="nflb-pub-main"/>
          </publicationLinks>

          <categoryLinks>
            <categoryLink id="nflb-cl-pcs-inf" name="Infantry" hidden="false"
                          targetId="96c1-32dc-d9dc-4678" primary="false"/>
            <categoryLink id="nflb-cl-pcs-am" name="Faction: Astra Militarum"
                          hidden="false" targetId="fa45-57e-930e-602b" primary="false"/>
            <categoryLink id="nflb-cl-pcs-imp" name="Imperium" hidden="false"
                          targetId="8d6d-8c4b-f475-e74a" primary="false"/>
          </categoryLinks>

          <profiles>
            <profile id="nflb-prof-pcs-unit"
                     name="Platoon Command Squad"
                     hidden="false"
                     typeId="800f-21d0-4387-c943"
                     typeName="Unit">
              <characteristics>
                <characteristic name="M"  typeId="0bdf-a96e-9e17-haar">6"</characteristic>
                <characteristic name="T"  typeId="e7f0-1278-9c28-bval">3</characteristic>
                <characteristic name="SV" typeId="fb84-60a0-99b4-sval">5+</characteristic>
                <characteristic name="W"  typeId="a hit-3412-9bc3-wval">1</characteristic>
                <characteristic name="LD" typeId="2661-7f7e-dc44-lval">6+</characteristic>
                <characteristic name="OC" typeId="99ef-cbc6-1793-oval">2</characteristic>
              </characteristics>
            </profile>
          </profiles>

          <infoLinks>
            <infoLink id="nflb-il-pcs-orders" name="Issue Orders" hidden="false"
                      targetId="nflb-prof-ability-orders" type="profile"/>
          </infoLinks>

          <!-- Default weapons for all PCS models -->
          <selectionEntries>
            <selectionEntry id="nflb-se-pcs-laspistol" name="Laspistol"
                            hidden="false" collective="false" import="true" type="upgrade">
              <infoLinks>
                <infoLink id="nflb-il-pcs-lp" name="Laspistol" hidden="false"
                          targetId="nflb-prof-laspistol" type="profile"/>
              </infoLinks>
              <costs><cost name="pts" typeId="points" value="0"/></costs>
            </selectionEntry>
            <selectionEntry id="nflb-se-pcs-ccw" name="Close Combat Weapon"
                            hidden="false" collective="false" import="true" type="upgrade">
              <infoLinks>
                <infoLink id="nflb-il-pcs-ccw" name="Close Combat Weapon" hidden="false"
                          targetId="nflb-prof-ccw" type="profile"/>
              </infoLinks>
              <costs><cost name="pts" typeId="points" value="0"/></costs>
            </selectionEntry>
          </selectionEntries>

          <!-- Exactly 1 PCS per platoon -->
          <constraints>
            <constraint id="nflb-con-pcs-min" type="min" value="1"
                        field="selections" scope="parent" shared="true"/>
            <constraint id="nflb-con-pcs-max" type="max" value="1"
                        field="selections" scope="parent" shared="true"/>
          </constraints>

          <!-- 40pts flat for the full 4-model PCS -->
          <costs>
            <cost name="pts" typeId="points" value="40"/>
          </costs>

        </selectionEntry>

        <!-- ======================================================
             INFANTRY SQUAD — 2 minimum, 5 maximum per platoon
             10 models: 1 Sergeant + 9 Guardsmen
             55pts flat per squad
             ====================================================== -->
        <selectionEntry id="nflb-se-is"
                        name="Infantry Squad"
                        hidden="false"
                        collective="false"
                        import="true"
                        type="unit">

          <publicationLinks>
            <publicationLink id="nflb-pl-is" targetId="nflb-pub-main"/>
          </publicationLinks>

          <categoryLinks>
            <categoryLink id="nflb-cl-is-inf" name="Infantry" hidden="false"
                          targetId="96c1-32dc-d9dc-4678" primary="false"/>
            <categoryLink id="nflb-cl-is-am" name="Faction: Astra Militarum"
                          hidden="false" targetId="fa45-57e-930e-602b" primary="false"/>
            <categoryLink id="nflb-cl-is-imp" name="Imperium" hidden="false"
                          targetId="8d6d-8c4b-f475-e74a" primary="false"/>
          </categoryLinks>

          <profiles>
            <profile id="nflb-prof-is-unit"
                     name="Infantry Squad"
                     hidden="false"
                     typeId="800f-21d0-4387-c943"
                     typeName="Unit">
              <characteristics>
                <characteristic name="M"  typeId="0bdf-a96e-9e17-haar">6"</characteristic>
                <characteristic name="T"  typeId="e7f0-1278-9c28-bval">3</characteristic>
                <characteristic name="SV" typeId="fb84-60a0-99b4-sval">5+</characteristic>
                <characteristic name="W"  typeId="a hit-3412-9bc3-wval">1</characteristic>
                <characteristic name="LD" typeId="2661-7f7e-dc44-lval">7+</characteristic>
                <characteristic name="OC" typeId="99ef-cbc6-1793-oval">2</characteristic>
              </characteristics>
            </profile>
          </profiles>

          <selectionEntries>
            <selectionEntry id="nflb-se-is-lasgun" name="Lasgun"
                            hidden="false" collective="false" import="true" type="upgrade">
              <infoLinks>
                <infoLink id="nflb-il-is-lg" name="Lasgun" hidden="false"
                          targetId="nflb-prof-lasgun" type="profile"/>
              </infoLinks>
              <costs><cost name="pts" typeId="points" value="0"/></costs>
            </selectionEntry>
            <selectionEntry id="nflb-se-is-frag" name="Frag Grenade"
                            hidden="false" collective="false" import="true" type="upgrade">
              <infoLinks>
                <infoLink id="nflb-il-is-fg" name="Frag Grenade" hidden="false"
                          targetId="nflb-prof-frag" type="profile"/>
              </infoLinks>
              <costs><cost name="pts" typeId="points" value="0"/></costs>
            </selectionEntry>
            <selectionEntry id="nflb-se-is-krak" name="Krak Grenade"
                            hidden="false" collective="false" import="true" type="upgrade">
              <infoLinks>
                <infoLink id="nflb-il-is-kg" name="Krak Grenade" hidden="false"
                          targetId="nflb-prof-krak" type="profile"/>
              </infoLinks>
              <costs><cost name="pts" typeId="points" value="0"/></costs>
            </selectionEntry>
          </selectionEntries>

          <!-- 2 to 5 squads per platoon -->
          <constraints>
            <constraint id="nflb-con-is-min" type="min" value="2"
                        field="selections" scope="parent" shared="true"/>
            <constraint id="nflb-con-is-max" type="max" value="5"
                        field="selections" scope="parent" shared="true"/>
          </constraints>

          <!-- 55pts flat per 10-model Infantry Squad -->
          <costs>
            <cost name="pts" typeId="points" value="55"/>
          </costs>

        </selectionEntry>

      </selectionEntries>

    </selectionEntry>

  </sharedSelectionEntries>

  <!-- ============================================================
       ENTRY LINKS
       This is what makes the Infantry Platoon appear as an
       additional Troops choice inside the official AM army builder,
       sitting alongside standard units like Infantry Squad,
       Conscripts, etc. Players see it listed as [NFLB] so it's
       clearly marked as homebrew.
       ============================================================ -->
  <entryLinks>
    <entryLink id="nflb-el-platoon"
               name="Infantry Platoon [NFLB]"
               hidden="false"
               collective="false"
               import="true"
               targetId="nflb-se-platoon"
               type="selectionEntry">
      <categoryLinks>
        <categoryLink id="nflb-cl-el-troops"
                      name="Troops"
                      hidden="false"
                      targetId="3d52-fccf-a302-troops"
                      primary="true"/>
      </categoryLinks>
    </entryLink>
  </entryLinks>

</catalogue>
