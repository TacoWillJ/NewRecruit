    <profile id="nflb-prof-krak"
             name="Krak Grenade"
             hidden="false"
             typeId="d5f97c0b-9fc9-478d-aa34-a7c414d3f5ce"
             typeName="Weapon">
      <characteristics>
        <characteristic name="Range"  typeId="6fa97fa8-ea74-4a27-a0fb-bc4e4fe1d0a8">6"</characteristic>
        <characteristic name="A"      typeId="de14-g33f-c33f-atks">1</characteristic>
        <characteristic name="BS"     typeId="fc32-7721-5c1c-bsval">4+</characteristic>
        <characteristic name="S"      typeId="59b1-319e-ec13-sval">6</characteristic>
        <characteristic name="AP"     typeId="75aa-a838-b675-apval">-1</characteristic>
