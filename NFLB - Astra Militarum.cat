<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<catalogue xmlns="http://www.battlescribe.net/schema/catalogueSchema"
  id="nflb-0001-am00-0001"
  name="NFLB - Astra Militarum"
  gameSystemId="sys-352e-adc2-7639-d6a9"
  gameSystemRevision="38"
  revision="1"
  battleScribeVersion="2.03"
  authorName="No Figure Left Behind"
  authorContact="https://tacowillj.github.io/nofigureleftbehind.github.io/"
  authorUrl="https://tacowillj.github.io/nofigureleftbehind.github.io/"
  library="false"
  type="catalogue">

  <!--
    ================================================================
    NO FIGURE LEFT BEHIND — Astra Militarum Supplement
    ================================================================
    This is a SUPPLEMENT catalogue, not a replacement.

    How it works:
      - Players select the official "Imperium - Astra Militarum"
        catalogue as normal when building their army.
      - They then ALSO add this catalogue as a second catalogue link
        in New Recruit, giving them access to NFLB homebrew units
        alongside ALL standard AM units.
      - Nothing is removed. Everything is added.

    This file inherits from the official AM catalogue so it shares
    all keywords, faction rules, and detachment abilities.

    Version 1 — Infantry Platoon v3 test build
    ================================================================
  -->

  <!-- ============================================================
       PUBLICATIONS
       Defines the NFLB source badge shown in New Recruit,
       same treatment as the Legends badge on GW Legends units.
       ============================================================ -->
  <publications>
    <publication id="nflb-pub-main"
                 name="No Figure Left Behind"
                 shortName="NFLB"
                 publisherUrl="https://tacowillj.github.io/nofigureleftbehind.github.io/"/>
  </publications>

  <!-- ============================================================
       CATALOGUE LINKS
       Inherit from the official Astra Militarum catalogue.
       This gives us access to all official shared entries and means
       our units automatically carry the correct faction keywords.
       ============================================================ -->
  <catalogueLinks>
    <catalogueLink
      id="nflb-link-official-am"
      name="Imperium - Astra Militarum"
      hidden="false"
      targetId="b0ae-12a5-c84-ea45"
      type="catalogue"
      importRootEntries="true"/>
  </catalogueLinks>

  <!-- ============================================================
       SHARED PROFILES
       Ability text blocks referenced by our units below.
       ============================================================ -->
  <sharedProfiles>

    <profile id="nflb-prof-ability-coc"
             name="Chain of Command"
             hidden="false"
             typeId="72c5eafc-75bf-4ed9-b425-78009f1bbe49"
             typeName="Ability">
      <characteristics>
        <characteristic name="Description"
                        typeId="21befb24-fc85-4f52-a745-64b2e48f8228">
          While this Platoon contains a Platoon Command Squad, Infantry Squads
          within 6" of it may use the Platoon Command Squad's Leadership
          characteristic instead of their own. If the Platoon Command Squad is
          destroyed, Infantry Squads in this Platoon lose this ability for the
          rest of the battle.
        </characteristic>
      </characteristics>
    </profile>

    <profile id="nflb-prof-ability-won"
             name="Weight of Numbers"
             hidden="false"
             typeId="72c5eafc-75bf-4ed9-b425-78009f1bbe49"
             typeName="Ability">
      <characteristics>
        <characteristic name="Description"
                        typeId="21befb24-fc85-4f52-a745-64b2e48f8228">
          Each time an attack is made against an Infantry Squad in this Platoon,
          if that unit contains 6 or more models, subtract 1 from the Wound roll.
        </characteristic>
      </characteristics>
    </profile>

    <profile id="nflb-prof-ability-orders"
             name="Issue Orders"
             hidden="false"
             typeId="72c5eafc-75bf-4ed9-b425-78009f1bbe49"
             typeName="Ability">
      <characteristics>
        <characteristic name="Description"
                        typeId="21befb24-fc85-4f52-a745-64b2e48f8228">
          At the start of your Command phase, the Platoon Commander may issue
          one of the following orders to one Infantry Squad within 6":
          MOVE MOVE MOVE (that unit may make a Normal Move of up to 3"
          immediately), TAKE AIM (that unit's ranged weapons gain [LETHAL HITS]
          until the end of the turn), or GET DOWN (that unit gains a 6+
          invulnerable save until the start of your next Command phase).
        </characteristic>
      </characteristics>
    </profile>

    <!-- Weapons -->
    <profile id="nflb-prof-lasgun"
             name="Lasgun"
             hidden="false"
             typeId="d5f97c0b-9fc9-478d-aa34-a7c414d3f5ce"
             typeName="Weapon">
      <characteristics>
        <characteristic name="Range"  typeId="6fa97fa8-ea74-4a27-a0fb-bc4e4fe1d0a8">24"</characteristic>
        <characteristic name="A"      typeId="de14-g33f-c33f-atks">1</characteristic>
        <characteristic name="BS"     typeId="fc32-7721-5c1c-bsval">4+</characteristic>
        <characteristic name="S"      typeId="59b1-319e-ec13-sval">3</characteristic>
        <characteristic name="AP"     typeId="75aa-a838-b675-apval">0</characteristic>
        <characteristic name="D"      typeId="ae8a-3137-d6-dmgval">1</characteristic>
        <characteristic name="Keywords" typeId="ability-keywords-id">[RAPID FIRE 1]</characteristic>
      </characteristics>
    </profile>

    <profile id="nflb-prof-laspistol"
             name="Laspistol"
             hidden="false"
             typeId="d5f97c0b-9fc9-478d-aa34-a7c414d3f5ce"
             typeName="Weapon">
      <characteristics>
        <characteristic name="Range"  typeId="6fa97fa8-ea74-4a27-a0fb-bc4e4fe1d0a8">12"</characteristic>
        <characteristic name="A"      typeId="de14-g33f-c33f-atks">1</characteristic>
        <characteristic name="BS"     typeId="fc32-7721-5c1c-bsval">4+</characteristic>
        <characteristic name="S"      typeId="59b1-319e-ec13-sval">3</characteristic>
        <characteristic name="AP"     typeId="75aa-a838-b675-apval">0</characteristic>
        <characteristic name="D"      typeId="ae8a-3137-d6-dmgval">1</characteristic>
        <characteristic name="Keywords" typeId="ability-keywords-id">[PISTOL]</characteristic>
      </characteristics>
    </profile>

    <profile id="nflb-prof-ccw"
             name="Close Combat Weapon"
             hidden="false"
             typeId="d5f97c0b-9fc9-478d-aa34-a7c414d3f5ce"
             typeName="Weapon">
      <characteristics>
        <characteristic name="Range"  typeId="6fa97fa8-ea74-4a27-a0fb-bc4e4fe1d0a8">Melee</characteristic>
        <characteristic name="A"      typeId="de14-g33f-c33f-atks">1</characteristic>
        <characteristic name="BS"     typeId="fc32-7721-5c1c-bsval">4+</characteristic>
        <characteristic name="S"      typeId="59b1-319e-ec13-sval">3</characteristic>
        <characteristic name="AP"     typeId="75aa-a838-b675-apval">0</characteristic>
        <characteristic name="D"      typeId="ae8a-3137-d6-dmgval">1</characteristic>
        <characteristic name="Keywords" typeId="ability-keywords-id">-</characteristic>
      </characteristics>
    </profile>

    <profile id="nflb-prof-frag"
             name="Frag Grenade"
             hidden="false"
             typeId="d5f97c0b-9fc9-478d-aa34-a7c414d3f5ce"
             typeName="Weapon">
      <characteristics>
        <characteristic name="Range"  typeId="6fa97fa8-ea74-4a27-a0fb-bc4e4fe1d0a8">6"</characteristic>
        <characteristic name="A"      typeId="de14-g33f-c33f-atks">D6</characteristic>
        <characteristic name="BS"     typeId="fc32-7721-5c1c-bsval">4+</characteristic>
        <characteristic name="S"      typeId="59b1-319e-ec13-sval">3</characteristic>
        <characteristic name="AP"     typeId="75aa-a838-b675-apval">0</characteristic>
